# --- PostgreSQL ---
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=canterlot
PG_USER=canterlot
PG_PASSWORD=请修改此密码

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=请修改此密码
